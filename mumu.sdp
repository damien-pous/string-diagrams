let A<color=red> in
let B<color=blue> in
let m: A^2 -> A in
let n: B^2-> B in
let x<color=cacadoie>: B⊗A -> A⊗B in
let mn := id·x·id ; m·n in
let M: m·id ; m ≡ id·m ; m in
let N: n·id ; n ≡ id·n ; n in
let MX: id·m ; x ≡ x·id ; id·x ; m·id in
let NX: n·id ; x ≡ id·x ; x·id ; id·n in
(id·x·id ; m·n)·id·id ; (id·x·id ; m·n) ≡ id·id·(id·x·id ; m·n) ; (id·x·id ; m·n)
