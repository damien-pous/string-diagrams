// let A<color=red>: ⊗ in
// let B<color=blue>: ⊗ in
let m<color=red;shape=triangle>: A^2 -> A in
let n<color=blue;shape=triangle>: B^2-> B in
let x<color=cacadoie;shape=cross>: B⊗A -> A⊗B in
let mn := id·x·id ; m·n in
m·id ; m = id·m ; m ->
n·id ; n = id·n ; n ->
id·m ; x = x·id ; id·x ; m·id ->
n·id ; x = id·x ; x·id ; id·n ->
(id·x·id ; m·n)·id·id ; (id·x·id ; m·n) ≡ id·id·(id·x·id ; m·n) ; (id·x·id ; m·n)
